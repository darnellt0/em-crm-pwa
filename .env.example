DATABASE_URL="postgresql://em_app:em_secure_password@localhost:5432/em_crm"

# Generate with: openssl rand -base64 32
AUTH_SECRET="generate_with_openssl_rand_base64_32"
AUTH_URL="http://localhost:3000"

# MailHog (local email catcher) — use localhost when running Next.js on host
SMTP_HOST="localhost"
SMTP_PORT="1025"
EMAIL_FROM="Elevated Movements <no-reply@localhost>"

# Ollama — use http://127.0.0.1:11434 when Next.js runs on host (not in Docker)
# Use http://host.docker.internal:11434 only if Next.js runs inside Docker
OLLAMA_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen2.5:7b-instruct"
OLLAMA_EMBED_MODEL="nomic-embed-text"

# Internal token for embedding worker / n8n calls (used as x-internal-token header)
INTERNAL_SERVICE_TOKEN="change_me_long_random"

# Seed user emails (used by pnpm db:seed — override if your addresses differ)
SEED_DARNELL_EMAIL="darnell@elevatedmovements.com"
SEED_SHRIA_EMAIL="shria@elevatedmovements.com"
